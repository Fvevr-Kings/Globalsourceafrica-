# Supabase — storefront uses the anon key (browser + server reads via public view).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side ONLY. Used by order placement (bypasses RLS to resolve tier pricing
# and write orders) and by the seed script. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: default display locale/currency. Phase 1 ships en-US / USD.
NEXT_PUBLIC_DEFAULT_LOCALE=en-US
NEXT_PUBLIC_DEFAULT_CURRENCY=USD

# Demo mode: render bundled sample products with NO backend. Auto-ON when the
# Supabase URL/anon key above are missing. Set =true to force it even with keys.
NEXT_PUBLIC_DEMO_MODE=false

# Hero banner media (optional). Drop a file in /public and point here, e.g.
#   NEXT_PUBLIC_BANNER_URL=/banner.gif   (GIF or image)
#   NEXT_PUBLIC_BANNER_URL=/banner.mp4   (video; loops, muted, autoplay)
# Leave empty to use the built-in branded animated graphic.
NEXT_PUBLIC_BANNER_URL=
NEXT_PUBLIC_BANNER_POSTER=
